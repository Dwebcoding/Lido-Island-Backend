# Esempio di variabili d'ambiente per backend
# Copia questo file in ".env" e riempi i valori reali in produzione.

# =====================
# Stripe
# =====================
# Chiave segreta Stripe (livello test o live). Non condividere.
STRIPE_SECRET_KEY=sk_test_xxx

# Segreto webhook (ottenuto da dashboard Stripe o `stripe listen`)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# URL di successo / cancellazione usati da Checkout
SUCCESS_URL=https://tuo-dominio.it/success.html
CANCEL_URL=https://tuo-dominio.it/index.html

# Consenti fallback insicuro solo in sviluppo (false in produzione)
# VALORE CONSIGLIATO: false
ALLOW_INSECURE_WEBHOOK=false

# =====================
# Database / Server
# =====================
# Stringa di connessione DB
MONGO_URI=mongodb://localhost:27017/lido
PORT=3000

# =====================
# SMTP (per inviare email)
# =====================
# SMTP_HOST: hostname del server SMTP (es. smtp.gmail.com, smtp.sendgrid.net)
# SMTP_PORT: porta (587 per STARTTLS, 465 per SSL)
# SMTP_USER: username per autenticazione (spesso l'indirizzo email che invia)
# SMTP_PASS: password o api key (per Gmail usa App Password se 2FA abilitato)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_password_or_api_key

# Indirizzi email
FROM_EMAIL=postamaster@isolalido.it
# Email dove arrivano le prenotazioni (proprietario)
OWNER_EMAIL=isolalido@outlook.com

# =====================
# Twilio (opzionale - per SMS)
# =====================
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
TWILIO_FROM=+1234567890

